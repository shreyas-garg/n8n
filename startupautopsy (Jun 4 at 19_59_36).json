    {
      "parameters": {
        "jsCode": "function extractScore(agentOutput) {\n  try {\n    const text = agentOutput.first().json.output[0].content[0].text;\n    return JSON.parse(text);\n  } catch(e) {\n    const raw = agentOutput.first().json.output;\n    const text = typeof raw === 'string' ? raw : JSON.stringify(raw);\n    const match = text.match(/\\{[\\s\\S]*\\}/);\n    if (match) return JSON.parse(match[0]);\n    throw new Error('Could not extract score from: ' + text);\n  }\n}\n\nconst clarity = extractScore($('Problem Clarity Agent'));\nconst market = extractScore($('Market Research Agent'));\nconst competition = extractScore($('Competition Checker Agent'));\n\nconst avg = (clarity.score + market.score + competition.score) / 3;\n\nlet verdict;\nif (avg >= 7) verdict = \"Promising\";\nelse if (avg >= 5) verdict = \"Needs Work\";\nelse verdict = \"Pivot\";\n\nreturn [{\n  json: {\n    clarity_score: clarity.score,\n    market_score: market.score,\n    competition_score: competition.score,\n    average_score: Math.round(avg * 10) / 10,\n    verdict,\n    clarity_feedback: clarity.feedback,\n    competitors: competition.top_competitors,\n    moat: competition.moat_assessment,\n    market_size: market.market_size,\n    all_outputs: { clarity, market, competition }\n  }\n}];"
      },
