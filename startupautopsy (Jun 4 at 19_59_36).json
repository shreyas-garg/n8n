    {
      "parameters": {
        "jsCode": "function extractJSON(agentOutput) {\n  try {\n    const text = agentOutput.first().json.output[0].content[0].text;\n    return JSON.parse(text);\n  } catch(e) {\n    return {};\n  }\n}\n\nconst reasoning = extractJSON($('Reasoning Reconstructor'));\nconst assumptions = extractJSON($('Assumption Extractor'));\nconst errors = extractJSON($('Error Detector'));\n\nconst baseScore = $('Scoring Logic').first().json.average_score / 10;\n\nlet confidence = baseScore;\nif (errors.errors_found) confidence -= 0.2;\nif (errors.hallucination_risk === 'high') confidence -= 0.15;\nif (assumptions.riskiest_assumption) confidence -= 0.05;\nconfidence = Math.max(0, Math.min(1, confidence));\n\nlet risk, failure_type;\nif (confidence < 0.4) { risk = \"critical\"; failure_type = \"hallucination_or_logic_error\"; }\nelse if (confidence < 0.6) { risk = \"medium\"; failure_type = \"unverified_assumptions\"; }\nelse { risk = \"low\"; failure_type = \"none\"; }\n\nreturn [{ json: { \n  ...($('Scoring Logic').first().json), \n  confidence: Math.round(confidence * 100) / 100, \n  risk, \n  failure_type, \n  reasoning_steps: reasoning.reasoning_steps || null,\n  riskiest_assumption: assumptions.riskiest_assumption || null,\n  errors_found: errors.errors_found || false,\n  critical_issue: errors.most_critical_issue || null\n}}];"
      },
